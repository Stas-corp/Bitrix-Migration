<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Все записи здесь используют XML IDs модуля
        `odoo_document_management_cloud_sync` (платный, в .gitignore проекта).
        Это override-pattern: наш модуль является bridge'ом, который через
        depends гарантированно загружается ПОСЛЕ оригинала, и через `<record>`
        с XML IDs оригинала перезаписывает его записи правильными значениями.

        Группа Document User по умолчанию имеет implied_ids → base.group_user.
        Поэтому НЕЛЬЗЯ оставлять любые ACL `Role / User` на document.* —
        Document User получит их через цепочку implied. Старые
        `Role / User` ACL чистятся в hooks/post_init.py.
    -->

    <data noupdate="1">

        <!-- ===================================================== -->
        <!-- Group fix: Document Manager должен implies Document User -->
        <!-- ===================================================== -->

        <record id="odoo_document_management_cloud_sync.group_document_manager" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('odoo_document_management_cloud_sync.group_document_user'))]"/>
        </record>

        <!-- ===================================================== -->
        <!-- Override 12 ACL для group_document_user                -->
        <!-- ===================================================== -->

        <record id="odoo_document_management_cloud_sync.access_document_folder_user" model="ir.model.access">
            <field name="name">document.folder.user</field>
            <field name="model_id" search="[('model', '=', 'document.folder')]" model="ir.model"/>
            <field name="group_id" ref="odoo_document_management_cloud_sync.group_document_user"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="odoo_document_management_cloud_sync.access_document_file_user" model="ir.model.access">
