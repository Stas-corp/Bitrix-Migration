<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_avatar_sync" model="ir.cron">
            <field name="name">Bitrix Migration: Process Avatar Batch</field>
            <field name="model_id" ref="model_bitrix_migration_run"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="state">code</field>
            <field name="code">model._cron_process_avatar_batch()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
        <record id="ir_cron_attachment_sync" model="ir.cron">
            <field name="name">Bitrix Migration: Process Attachment Batch</field>
            <field name="model_id" ref="model_bitrix_migration_run"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="state">code</field>
            <field name="code">model._cron_process_attachment_batch()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
