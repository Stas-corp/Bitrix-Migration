<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_task_form_bitrix_migration" model="ir.ui.view">
        <field name="name">project.task.form.bitrix.migration</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='date_deadline_and_recurring_task']" position="after">
                <group>
                    <field name="x_bitrix_created_at"
                           readonly="1"
                           invisible="not x_bitrix_created_at"/>
                </group>
            </xpath>
            <xpath expr="//field[@name='role_ids']" position="attributes">
                <attribute name="groups">project.group_project_user,project.group_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="x_bitrix_responsible_employee_id"
                       readonly="1"
                       optional="show"
                       invisible="not x_bitrix_responsible_employee_id"
                       string="Відповідальний"/>
                <field name="x_bitrix_accomplice_employee_ids"
                       widget="many2many_tags"
                       readonly="1"
                       optional="show"
                       invisible="not x_bitrix_accomplice_employee_ids"
                       string="Співвиконавці"/>
                <field name="x_bitrix_auditor_employee_ids"
                       widget="many2many_tags"
                       readonly="1"
                       optional="show"
                       invisible="not x_bitrix_auditor_employee_ids"
                       string="Наглядачі"/>
                <field name="x_bitrix_originator_employee_id"
                       readonly="1"
                       optional="show"
                       invisible="not x_bitrix_originator_employee_id"
                       string="Постановник"/>
                <field name="x_bitrix_creator_employee_id"
                       readonly="1"
                       optional="show"
                       invisible="not x_bitrix_creator_employee_id"
                       string="Створив"/>
            </xpath>
            <xpath expr="//field[@name='user_ids']" position="attributes">
                <attribute name="string">Odoo-виконавці</attribute>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="before">
                <label for="tag_ids" string="Мітки"/>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="attributes">
                <attribute name="string">Мітки</attribute>
                <attribute name="nolabel">1</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="before">
                <label for="partner_id"
                       string="Клієнт"
                       invisible="not project_id or has_template_ancestor or has_project_template"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="string">Клієнт</attribute>
                <attribute name="nolabel">1</attribute>
            </xpath>
            <xpath expr="//page[@name='extra_info']/group/group[2]" position="inside">
                <field name="x_bitrix_created_at"
                       readonly="1"
                       invisible="not x_bitrix_created_at"/>
                <field name="x_bitrix_id" readonly="1"/>
                <field name="x_bitrix_stage_id" readonly="1"/>
                <field name="x_bitrix_status_code" readonly="1"/>
                <field name="x_bitrix_parent_id" readonly="1"/>
                <field name="x_bitrix_assignee_user_ids"
                       widget="many2many_tags"
                       readonly="1"
                       invisible="not x_bitrix_assignee_user_ids"
                       string="Bitrix Assignees (Users)"/>
                <field name="x_bitrix_access_user_ids"
                       widget="many2many_tags"
                       readonly="1"
                       invisible="not x_bitrix_access_user_ids"
                       string="Bitrix Access Users"/>
            </xpath>
        </field>
    </record>

    <record id="view_project_task_templates_list_bitrix_migration" model="ir.ui.view">
        <field name="name">project.task.templates.list.bitrix.migration</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.project_task_templates_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='role_ids']" position="attributes">
                <attribute name="groups">project.group_project_user,project.group_project_manager</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_project_task_search_bitrix_migration" model="ir.ui.view">
        <field name="name">project.task.search.bitrix.migration</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_template_search_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='role_ids']" position="attributes">
                <attribute name="groups">project.group_project_user,project.group_project_manager</attribute>
            </xpath>
        </field>
    </record>

    <record id="action_project_task_my_bitrix_tasks" model="ir.actions.act_window">
        <field name="name">My Tasks</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">list,kanban,form,activity,calendar</field>
        <field name="domain">[('user_ids', 'in', [uid])]</field>
        <field name="context">{'create': False}</field>
        <field name="search_view_id" ref="project.view_task_search_form_base"/>
    </record>

    <record id="action_project_task_my_bitrix_watched" model="ir.actions.act_window">
        <field name="name">Watched Tasks</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">list,kanban,form,activity,calendar</field>
        <field name="domain">[('x_bitrix_auditor_employee_ids.user_id', '=', uid)]</field>
        <field name="context">{'create': False}</field>
        <field name="search_view_id" ref="project.view_task_search_form_base"/>
    </record>

    <record id="action_project_project_my_bitrix_projects" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">project.project</field>
        <field name="view_mode">kanban,list,form,activity</field>
        <field name="domain">['|', '|', '|', ('task_ids.user_ids', 'in', [uid]), ('task_ids.x_bitrix_auditor_employee_ids.user_id', '=', uid), ('task_ids.x_bitrix_originator_employee_id.user_id', '=', uid), ('task_ids.x_bitrix_creator_employee_id.user_id', '=', uid)]</field>
        <field name="context">{'create': False}</field>
    </record>

    <menuitem id="menu_my_bitrix_tasks"
              name="My Tasks"
              action="action_project_task_my_bitrix_tasks"
              sequence="35"
              groups="bitrix_migration.group_bitrix_task_employee"/>

    <menuitem id="menu_my_bitrix_watched_tasks"
              name="Watched Tasks"
              action="action_project_task_my_bitrix_watched"
              sequence="36"
              groups="bitrix_migration.group_bitrix_task_employee"/>

    <menuitem id="menu_my_bitrix_projects"
              name="Projects"
              action="action_project_project_my_bitrix_projects"
              sequence="37"
              groups="bitrix_migration.group_bitrix_task_employee"/>

</odoo>
