<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_task_form_bitrix_migration" model="ir.ui.view">
        <field name="name">project.task.form.bitrix.migration</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='date_deadline_and_recurring_task']" position="after">
                <group>
                    <field name="x_bitrix_created_at"
                           readonly="1"
                           invisible="not x_bitrix_created_at"/>
                </group>
            </xpath>
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="x_bitrix_creator_employee_id"
                       readonly="1"
                       optional="show"
                       invisible="not x_bitrix_creator_employee_id"
                       string="Постановщик (Bitrix)"/>
                <field name="x_bitrix_responsible_employee_ids"
                       widget="many2many_tags"
                       readonly="1"
                       optional="show"
                       invisible="not x_bitrix_responsible_employee_ids"/>
            </xpath>
            <xpath expr="//page[@name='extra_info']/group/group[2]" position="inside">
                <field name="x_bitrix_created_at"
                       readonly="1"
                       invisible="not x_bitrix_created_at"/>
                <field name="x_bitrix_id" readonly="1"/>
                <field name="x_bitrix_stage_id" readonly="1"/>
                <field name="x_bitrix_parent_id" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
