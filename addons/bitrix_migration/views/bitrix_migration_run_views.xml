<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_bitrix_migration_run_form" model="ir.ui.view">
        <field name="name">bitrix.migration.run.form</field>
        <field name="model">bitrix.migration.run</field>
        <field name="arch" type="xml">
            <form string="Bitrix Migration">
                <header>
                    <button name="action_run" string="Run Migration"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Are you sure you want to start the migration?"/>
                    <button name="action_reset" string="Reset"
                            type="object" class="btn-secondary"
                            invisible="state == 'draft'"/>
                    <button name="action_start_attachment_sync" string="Start/Resume Attachments"
                            type="object" class="btn-secondary"
                            invisible="not sftp_host or attachment_sync_state in ('pending', 'running')"
                            confirm="Queue attachment migration for background cron processing?"/>
                    <button name="action_create_employee_users" string="Create Employee Users"
                            type="object" class="btn-secondary"
                            invisible="state == 'running'"
                            confirm="Create or update Odoo users for imported Bitrix employees with restricted access to assigned Bitrix tasks only?"/>
                    <button name="action_fix_department_managers" string="Fix Department Managers"
                            type="object" class="btn-secondary"
                            invisible="state == 'running'"
                            confirm="Fill department managers from Bitrix UF_HEAD without changing employee managers?"/>
                    <button name="action_fix_employee_hierarchy" string="Fix Employee Hierarchy"
                            type="object" class="btn-secondary"
                            invisible="state == 'running'"
                            confirm="Recompute hr.employee.parent_id from Bitrix UF_HEAD chains for already imported employees?"/>
                    <button name="action_create_test_employee_user" string="Create Test Employee User"
                            type="object" class="btn-secondary"
                            invisible="state == 'running' or not test_employee_id"
                            confirm="Create or link an Odoo user for the selected test employee and grant restricted access to assigned Bitrix tasks only?"/>
                    <button name="action_send_password_reset" string="Send Password Reset"
                            type="object" class="btn-secondary"
                            invisible="state == 'running'"
                            confirm="Send password reset emails to employee users linked to imported Bitrix employees?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,running,done,error"/>
                </header>
                <sheet>
                    <group>
                        <group string="Migration Mode">
                            <field name="mode"/>
                            <group invisible="mode != 'hr'"
                                   colspan="2">
                                <div class="alert alert-info" role="alert">
                                    <strong>HR: Departments + Employees</strong> — імпортує ієрархію
                                    підрозділів hr.department, далі співробітників hr.employee і
                                    прив'язує керівників.
                                </div>
                            </group>
                        </group>
                        <group string="Options">
                            <field name="preserve_authorship"/>
                            <field name="migration_date_from"
                                   invisible="mode in ('hr', 'fix_roles', 'fix_attachments')"/>
                            <field name="fallback_project_id"
                                   options="{'no_create_edit': True}"
                                   invisible="mode in ('hr', 'fix_roles', 'fix_attachments', 'fix_descriptions')"
                                   placeholder="Auto-created if empty"/>
                            <field name="test_employee_id"
                                   options="{'no_create': True, 'no_open': True}"
                                   placeholder="Select imported employee for test user creation"/>
                            <field name="progress" widget="progressbar"/>
                        </group>
                    </group>
                    <group string="Avatar Sync"
                           invisible="not avatar_sync_state">
                        <group>
                            <field name="avatar_sync_state" readonly="1"/>
                            <field name="avatar_total_count" readonly="1"/>
                            <field name="avatar_processed_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="avatar_imported_count" readonly="1"/>
                            <field name="avatar_propagated_count" readonly="1"/>
                            <field name="avatar_error_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Attachment Sync"
                           invisible="not attachment_sync_state">
                        <group>
                            <field name="attachment_sync_state" readonly="1"/>
                            <field name="attachment_current_type" readonly="1"/>
                            <field name="attachment_current_index" readonly="1"/>
                            <field name="attachment_total_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="attachment_processed_count" readonly="1"/>
                            <field name="attachment_created_count" readonly="1"/>
                            <field name="attachment_skipped_count" readonly="1"/>
                            <field name="attachment_error_count" readonly="1"/>
                        </group>
                        <group string="Active Download"
                               invisible="not attachment_active_key">
                            <field name="attachment_active_key" readonly="1"/>
                            <field name="attachment_active_bytes" readonly="1"/>
                            <field name="attachment_active_expected_size" readonly="1"/>
                            <field name="attachment_active_tmp_path" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="MySQL Connection">
                            <group>
                                <group>
                                    <field name="mysql_host" placeholder="localhost"/>
                                    <field name="mysql_port"/>
                                    <field name="mysql_database" placeholder="bitrix_db"/>
                                </group>
                                <group>
                                    <field name="mysql_user" placeholder="root"/>
                                    <field name="mysql_password" password="True"/>
                                </group>
                            </group>
                        </page>
                        <page string="Files &amp; Avatars">
                            <group>
                                <group>
                                    <field name="sftp_host" placeholder="bitrix-server.local"/>
                                    <field name="sftp_port"/>
                                    <field name="sftp_user" placeholder="bitrix"/>
                                </group>
                                <group>
                                    <field name="sftp_key_path" placeholder="/path/to/key"/>
                                    <field name="sftp_base_path" placeholder="/home/bitrix/www"/>
                                </group>
                            </group>
                            <group string="Employee Avatars">
                                <group>
                                    <field name="avatar_download_mode"/>
                                    <field name="avatar_local_root" placeholder="/var/www/bitrix/upload"/>
                                </group>
                                <group>
                                    <field name="avatar_http_base_url" placeholder="https://bitrix.example.com"/>
                                    <field name="avatar_http_headers"
                                           placeholder='{"Cookie": "PHPSESSID=...", "User-Agent": "Mozilla/5.0"}'/>
                                </group>
                            </group>
                        </page>
                        <page string="Disk Import" invisible="mode != 'disk'">
                            <div class="alert alert-info" role="alert">
                                <strong>Bitrix Disk → Documents</strong>
                                <p style="margin:8px 0 0 0;">
                                    DevOps повинен заздалегідь скопіювати Bitrix
                                    upload-кореню (наприклад, /home/bitrix/www/upload/main)
                                    в Odoo-контейнер і змонтувати її як read-only volume
                                    (наприклад, /mnt/bitrix-disk).
                                </p>
                                <p style="margin:4px 0 0 0;">
                                    Loader сам нічого не качає по SFTP — він читає
                                    структуру з MySQL Bitrix і бере бінарники з
                                    локального FS за шляхом
                                    <code>&lt;Disk Local Root&gt;/&lt;SUBDIR&gt;/&lt;FILE_NAME&gt;</code>.
                                </p>
                            </div>
                            <group>
                                <group>
                                    <field name="disk_local_root"
                                           placeholder="/mnt/bitrix-disk"/>
                                    <field name="disk_skip_transfer"/>
                                </group>
                                <group>
                                    <field name="disk_storage_ids_csv"
                                           placeholder="e.g. 3,7,12"/>
                                    <field name="disk_include_trashed"/>
                                </group>
                            </group>
                            <group string="Storage filter">
                                <group>
                                    <field name="disk_include_user"/>
                                    <field name="disk_include_common"/>
                                    <field name="disk_include_group"/>
                                </group>
                                <group>
                                    <field name="disk_include_im"/>
                                    <field name="disk_active_users_only"/>
                                </group>
                            </group>
                            <div class="text-muted" style="margin-top:4px;">
                                <small>
                                    Чекбокси та CSV-фільтр комбінуються через AND:
                                    спочатку відбираються типи storage, потім —
                                    конкретні ID, якщо вказані.
                                </small>
                            </div>
                        </page>
                        <page string="Log Output">
                            <field name="log_output" readonly="1"
                                   widget="text" nolabel="1"
                                   placeholder="Migration log will appear here..."/>
                        </page>
                        <page string="Danger Zone">
                            <div class="alert alert-danger" role="alert">
                                <strong>Destructive actions</strong>
                                <p style="margin:8px 0 0 0;">
                                    These actions delete migrated records. Use them only when you intentionally
                                    want to clean migration data before another run.
                                </p>
                            </div>
                            <group>
                                <group string="Imported Bitrix Data">
                                    <button name="action_purge_data" string="Purge Imported Data"
                                            type="object" class="btn-danger"
                                            invisible="state == 'running'"
                                            confirm="This will delete imported Bitrix tasks, projects, stages, comments, meetings, attachments, tags, mappings and checkpoints. HR records are kept intact. Continue?"/>
                                    <p class="text-muted">
                                        Deletes imported Bitrix tasks, projects, stages, comments, meetings,
                                        attachments, tags, mappings and checkpoints. HR records are kept.
                                    </p>
                                </group>
                                <group string="HR Data">
                                    <button name="action_purge_hr_data" string="Purge HR Data"
                                            type="object" class="btn-danger"
                                            invisible="state == 'running'"
                                            confirm="This will delete all employees and departments in Odoo, plus employee-linked users and contacts, including pre-existing records not imported from Bitrix. Protected or still-linked users/contacts will be skipped and logged. Continue?"/>
                                    <p class="text-muted">
                                        Deletes employees, departments and employee-linked users/contacts in the
                                        HR cleanup scope. Protected or still-linked records are skipped and logged.
                                    </p>
                                </group>
                                <group string="Noise Accounts">
                                    <button name="action_purge_noise_preview" string="Purge Noise — Preview"
                                            type="object" class="btn-secondary"
                                            invisible="state == 'running'"/>
                                    <button name="action_purge_noise_apply" string="Purge Noise — Apply"
                                            type="object" class="btn-danger"
                                            invisible="state == 'running'"
                                            confirm="This permanently deletes hr.employee records imported from Bitrix users without UF_DEPARTMENT (imconnector_*, imopenlines_*, bots, Bitrix24 Network guests). Orphan partners are dropped. Linked mail.message author_id is reassigned to OdooBot. Continue?"/>
                                    <p class="text-muted">
                                        One-off cleanup: removes integration/network/bot accounts that were
                                        imported by mistake (no UF_DEPARTMENT in Bitrix). Run Preview first
                                        to see what would be deleted, then Apply.
                                    </p>
                                </group>
                                <group string="Orphan Contacts">
                                    <button name="action_purge_orphan_partners_preview" string="Purge Orphan Contacts — Preview"
                                            type="object" class="btn-secondary"
                                            invisible="state == 'running'"/>
                                    <button name="action_purge_orphan_partners_apply" string="Purge Orphan Contacts — Apply"
                                            type="object" class="btn-danger"
                                            invisible="state == 'running'"
                                            confirm="This permanently deletes res.partner records not linked to any hr.employee (active or archived). References from mail messages, followers, and calendar events are reassigned to OdooBot before deletion. System partners (companies, OdooBot, public/portal users, internal Odoo users, parent contacts) are protected. Continue?"/>
                                    <p class="text-muted">
                                        Removes res.partner records that have no link to any hr.employee
                                        (active or archived). Message authors are reassigned to OdooBot;
                                        followers and calendar links are removed. System and internal
                                        Odoo user partners are protected. Run Preview first.
                                    </p>
                                </group>
                                <group string="Project Followers">
                                    <button name="action_purge_project_followers_preview" string="Purge Project Followers — Preview"
                                            type="object" class="btn-secondary"
                                            invisible="state == 'running'"/>
                                    <button name="action_purge_project_followers_apply" string="Purge Project Followers — Apply"
                                            type="object" class="btn-danger"
                                            invisible="state == 'running'"
                                            confirm="This removes mail.followers on imported projects, keeping only the project manager (project.user_id). Required to make privacy_visibility='followers' actually restrict task visibility: standard Odoo rule lets any project follower see all tasks. Followers on individual tasks are not touched. Continue?"/>
                                    <p class="text-muted">
                                        Removes stale followers from imported `project.project` records,
                                        leaving only the project manager. Needed because legacy importer
                                        subscribed every task assignee to the parent project, which made
                                        the standard rule (`project_id.message_partner_ids in
                                        user.partner_id`) expose all tasks of a project. Run Preview first.
                                    </p>
                                </group>
                            </group>
                        </page>
                        <page string="Help">
                            <div class="o_bitrix_help" style="width:100%;">
                                <div class="alert alert-info" role="alert" style="margin-bottom:16px;">
                                    <strong>Швидкий сценарій запуску</strong>
                                    <ol style="margin:8px 0 0 18px;">
                                        <li>Заповніть MySQL Connection, а для вкладень або фото — налаштування Files &amp; Avatars.</li>
                                        <li>Для HR-міграції оберіть <b>HR: Departments + Employees</b>.</li>
                                        <li>Для задач, проєктів, коментарів і вкладень використовуйте <b>Full Migration</b>.</li>
                                        <li>Виконайте <b>Create Employee Users</b> і <b>Send Password Reset</b> для створення користувачів співробітникам.</li>
                                        <li><b>Purge HR Data</b> використовуйте лише для повного очищення всіх співробітників, підрозділів і повʼязаних employee users/contacts.</li>
                                    </ol>
                                </div>

                                <h4 style="margin:0 0 8px 0;">Режими</h4>
                                <ul class="text-muted" style="margin:0 0 16px 18px;">
                                    <li><b>HR: Departments + Employees</b> — спочатку імпортує підрозділи, потім співробітників і їх фото.</li>
                                    <li><b>Full Migration</b> — повна міграція користувачів, проєктів, задач, коментарів і вкладень.</li>
                                    <li><b>Meetings Only</b> — імпортує зустрічі, їх коментарі та вкладення.</li>
                                    <li><b>Fix Roles</b> — повторна синхронізація ролей учасників задач.</li>
                                    <li><b>Fix Attachments</b> — повторна привʼязка вкладень коментарів.</li>
                                    <li><b>Fix Descriptions</b> — відновлює порожні описи з Bitrix DISK FILE placeholders.</li>
                                </ul>

                                <h4 style="margin:0 0 8px 0;">Ключові опції</h4>
                                <ul class="text-muted" style="margin:0 0 16px 18px;">
                                    <li><b>Preserve Authorship</b> — зберігає авторів коментарів, якщо їх можна зіставити в Odoo.</li>
                                    <li><b>Import From Date</b> — обмежує імпорт датою початку.</li>
                                    <li><b>Fallback Project</b> — проєкт для задач без проєкту в Bitrix; якщо порожньо, створиться автоматично.</li>
                                    <li><b>Test Employee</b> — співробітник для перевірочного створення користувача і доступів.</li>
                                </ul>

                                <h4 style="margin:0 0 8px 0;">Danger Zone</h4>
                                <ul class="text-muted" style="margin:0 0 16px 18px;">
                                    <li><b>Purge Imported Data</b> — видаляє лише імпортовані Bitrix-сутності; HR-записи не чіпає.</li>
                                    <li><b>Purge HR Data</b> — видаляє всі `hr.employee` і `hr.department`, а також повʼязані `res.users` / `res.partner` у HR-скоупі.</li>
                                    <li>Захищені користувачі або контакти, які неможливо видалити, будуть пропущені; деталі дивіться у <b>Log Output</b>.</li>
                                </ul>

                                <h4 style="margin:0 0 8px 0;">Troubleshooting</h4>
                                <ul class="text-muted" style="margin:0 0 0 18px;">
                                    <li>Усі деталі виконання дивіться на вкладці <b>Log Output</b>.</li>
                                    <li>Фото співробітників можна тягнути через SFTP, локальну папку upload або HTTP, залежно від Avatar Source.</li>
                                    <li>Якщо вкладення не потрібні, SFTP можна не заповнювати, але для фото має бути хоча б одне джерело.</li>
                                    <li>Якщо міграція завершилась з <b>Error</b>, перевірте останні рядки логу та параметри підключення.</li>
                                </ul>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bitrix_migration_run" model="ir.actions.server">
        <field name="name">Bitrix Migration</field>
        <field name="model_id" ref="model_bitrix_migration_run"/>
        <field name="state">code</field>
        <field name="code">action = env['bitrix.migration.run'].get_singleton_action()</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_bitrix_migration_root"
              name="Bitrix Migration"
              parent="base.menu_custom"
              action="action_bitrix_migration_run"
              sequence="100"/>

</odoo>
