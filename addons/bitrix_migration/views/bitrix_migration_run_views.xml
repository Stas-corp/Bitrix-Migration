<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_bitrix_migration_run_form" model="ir.ui.view">
        <field name="name">bitrix.migration.run.form</field>
        <field name="model">bitrix.migration.run</field>
        <field name="arch" type="xml">
            <form string="Bitrix Migration">
                <header>
                    <button name="action_run" string="Run Migration"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Are you sure you want to start the migration?"/>
                    <button name="action_reset" string="Reset"
                            type="object" class="btn-secondary"
                            invisible="state == 'draft'"/>
                    <button name="action_purge_data" string="Purge Imported Data"
                            type="object" class="btn-danger"
                            invisible="state == 'running'"
                            confirm="This will delete imported Bitrix tasks, projects, stages, comments, meetings, attachments, tags, mappings and checkpoints. HR records are kept intact. Continue?"/>
                    <button name="action_create_employee_users" string="Create Employee Users"
                            type="object" class="btn-secondary"
                            invisible="state == 'running'"
                            confirm="Create or update Odoo users for imported Bitrix employees with restricted access to assigned Bitrix tasks only?"/>
                    <button name="action_create_test_employee_user" string="Create Test Employee User"
                            type="object" class="btn-secondary"
                            invisible="state == 'running' or not test_employee_id"
                            confirm="Create or link an Odoo user for the selected test employee and grant restricted access to assigned Bitrix tasks only?"/>
                    <button name="action_send_password_reset" string="Send Password Reset"
                            type="object" class="btn-secondary"
                            invisible="state == 'running'"
                            confirm="Send password reset emails to employee users linked to imported Bitrix employees?"/>
                    <button name="action_merge_personal_projects_to_fallback" string="Merge Personal Projects"
                            type="object" class="btn-secondary"
                            invisible="state == 'running'"
                            confirm="Move tasks from personal Bitrix projects into fallback project with fixed status stages and deactivate personal projects?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,running,done,error"/>
                </header>
                <sheet>
                    <group>
                        <group string="Migration Mode">
                            <field name="mode"/>
                            <field name="single_task_bitrix_id"
                                   invisible="mode != 'single_task'"
                                   placeholder="e.g. 12345"/>
                            <field name="pilot_project_ids"
                                   invisible="mode != 'pilot'"
                                   placeholder="e.g. 1,2,3"/>
                            <group invisible="mode not in ('hr', 'departments_only', 'employees_only')"
                                   colspan="2">
                                <div class="alert alert-info" role="alert">
                                    <strong>HR режими:</strong>
                                    <p style="margin:8px 0 4px 0;">
                                        <b>Departments Only</b> — створює ієрархію підрозділів
                                        hr.department із керівниками.
                                    </p>
                                    <p style="margin:0 0 4px 0;">
                                        <b>Employees Only</b> — створює hr.employee
                                        (підрозділи мають бути імпортовані раніше).
                                    </p>
                                    <p style="margin:0;">
                                        <b>Departments + Employees</b> — запускає обидва кроки
                                        в правильному порядку.
                                    </p>
                                </div>
                            </group>
                        </group>
                        <group string="Options">
                            <field name="preserve_authorship"/>
                            <field name="migration_date_from"
                                   invisible="mode in ('relink', 'comments', 'single_task', 'hr', 'departments_only', 'employees_only')"/>
                            <field name="fallback_project_id"
                                   options="{'no_create_edit': True}"
                                   invisible="mode in ('relink', 'comments', 'hr', 'departments_only', 'employees_only', 'projects_only')"
                                   placeholder="Auto-created if empty"/>
                            <field name="test_employee_id"
                                   options="{'no_create': True, 'no_open': True}"
                                   placeholder="Select imported employee for test user creation"/>
                            <field name="progress" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="MySQL Connection">
                            <group>
                                <group>
                                    <field name="mysql_host" placeholder="localhost"/>
                                    <field name="mysql_port"/>
                                    <field name="mysql_database" placeholder="bitrix_db"/>
                                </group>
                                <group>
                                    <field name="mysql_user" placeholder="root"/>
                                    <field name="mysql_password" password="True"/>
                                </group>
                            </group>
                        </page>
                        <page string="Files &amp; Avatars">
                            <group>
                                <group>
                                    <field name="sftp_host" placeholder="bitrix-server.local"/>
                                    <field name="sftp_port"/>
                                    <field name="sftp_user" placeholder="bitrix"/>
                                </group>
                                <group>
                                    <field name="sftp_key_path" placeholder="/path/to/key"/>
                                    <field name="sftp_base_path" placeholder="/home/bitrix/www"/>
                                </group>
                            </group>
                            <group string="Employee Avatars">
                                <group>
                                    <field name="avatar_download_mode"/>
                                    <field name="avatar_local_root" placeholder="/var/www/bitrix/upload"/>
                                </group>
                                <group>
                                    <field name="avatar_http_base_url" placeholder="https://bitrix.example.com"/>
                                    <field name="avatar_http_headers"
                                           placeholder='{"Cookie": "PHPSESSID=...", "User-Agent": "Mozilla/5.0"}'/>
                                </group>
                            </group>
                        </page>
                        <page string="Log Output">
                            <field name="log_output" readonly="1"
                                   widget="text" nolabel="1"
                                   placeholder="Migration log will appear here..."/>
                        </page>
                        <page string="Help">
                            <div class="o_bitrix_help" style="width:100%;">
                                <div class="alert alert-info" role="alert" style="margin-bottom:16px;">
                                    <strong>Швидкий сценарій запуску</strong>
                                    <ol style="margin:8px 0 0 18px;">
                                        <li>Заповніть MySQL Connection, а для вкладень або фото — налаштування Files &amp; Avatars.</li>
                                        <li>Для HR-міграції спочатку оберіть <b>HR: Departments + Employees</b> або потрібний HR-режим.</li>
                                        <li>Далі використовуйте інші режими: <b>Dry Run</b>, <b>Full Migration</b>, <b>Pilot</b> тощо.</li>
                                        <li>Виконайте <b>Create Employee Users</b> і <b>Send Password Reset</b> для створення користувачів співробітникам.</li>
                                    </ol>
                                </div>

                                <h4 style="margin:0 0 8px 0;">Режими</h4>
                                <ul class="text-muted" style="margin:0 0 16px 18px;">
                                    <li><b>HR: Departments + Employees</b> — спочатку імпортує підрозділи, потім співробітників і їх фото.</li>
                                    <li><b>HR: Departments Only</b> — тільки структура підрозділів і керівники.</li>
                                    <li><b>HR: Employees Only</b> — тільки співробітники (після імпорту підрозділів).</li>
                                    <li><b>Dry Run</b> — лише підрахунок сутностей без запису в Odoo.</li>
                                    <li><b>Full Migration</b> — повна міграція користувачів, проєктів, задач, коментарів і вкладень.</li>
                                    <li><b>Pilot</b> — обмежений запуск для перевірки на вибіркових проєктах.</li>
                                    <li><b>Projects Only</b> — тільки користувачі, теги, проєкти та стадії.</li>
                                    <li><b>Relink Parents</b> — лише перев'язка батьківських задач.</li>
                                    <li><b>Comments Only</b> — лише імпорт коментарів.</li>
                                    <li><b>Single Task Test</b> — точковий імпорт однієї задачі.</li>
                                </ul>

                                <h4 style="margin:0 0 8px 0;">Ключові опції</h4>
                                <ul class="text-muted" style="margin:0 0 16px 18px;">
                                    <li><b>Preserve Authorship</b> — зберігає авторів коментарів, якщо їх можна зіставити в Odoo.</li>
                                    <li><b>Import From Date</b> — обмежує імпорт датою початку.</li>
                                    <li><b>Fallback Project</b> — проєкт для задач без проєкту в Bitrix; якщо порожньо, створиться автоматично.</li>
                                    <li><b>Test Employee</b> — співробітник для перевірочного створення користувача і доступів.</li>
                                </ul>

                                <h4 style="margin:0 0 8px 0;">Troubleshooting</h4>
                                <ul class="text-muted" style="margin:0 0 0 18px;">
                                    <li>Усі деталі виконання дивіться на вкладці <b>Log Output</b>.</li>
                                    <li>Фото співробітників можна тягнути через SFTP, локальну папку upload або HTTP, залежно від Avatar Source.</li>
                                    <li>Якщо вкладення не потрібні, SFTP можна не заповнювати, але для фото має бути хоча б одне джерело.</li>
                                    <li>Якщо міграція завершилась з <b>Error</b>, перевірте останні рядки логу та параметри підключення.</li>
                                </ul>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bitrix_migration_run" model="ir.actions.server">
        <field name="name">Bitrix Migration</field>
        <field name="model_id" ref="model_bitrix_migration_run"/>
        <field name="state">code</field>
        <field name="code">action = env['bitrix.migration.run'].get_singleton_action()</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_bitrix_migration_root"
              name="Bitrix Migration"
              parent="base.menu_custom"
              action="action_bitrix_migration_run"
              sequence="100"/>

</odoo>
